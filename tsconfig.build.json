{
  "extends": "./tsconfig.json", // inherits everything above
  "compilerOptions": {
    // These two flags are REMOVED — they block emit
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": false,

    "noEmit": false, // now tsc actually writes files
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "index.ts"], // Ambient type declarations
  "exclude": ["node_modules", "dist", "coverage", "**/*.test.ts", "**/*.spec.ts"]
}
