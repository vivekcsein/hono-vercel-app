{
	"$schema": "https://json.schemastore.org/tsconfig",

	"extends": "./tsconfig.json",

	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true
	},

	"include": ["index.ts", "src/**/*.ts", "src/**/*.tsx"],

	"exclude": ["tests", "**/*.test.ts", "**/*.spec.ts", "**/__tests__/**"]
}
