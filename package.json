{
	"name": "hono-vercel-app",
	"version": "0.0.0",
	"description": "A hono web services/backend project starter to host on vercel",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --watch src/app/server.ts",
		"build": "rspack build",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"verify": "bun run typecheck && bun run check && bun run build",
		"clean": "rimraf node_modules bun.lock dist"
	},
	"dependencies": {
		"hono": "^4.12.27",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@rspack/cli": "^2.1.1",
		"@rspack/core": "^2.1.1",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.1",
		"@vercel/node": "^5.8.22",
		"rimraf": "^6.1.3",
		"ts-checker-rspack-plugin": "^1.5.1"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	}
}
