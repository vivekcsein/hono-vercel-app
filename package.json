{
  "name": "hono-vercel-app",
  "description": "A hono web services/backend project starter to host on vercel",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rimraf dist && rimraf .tsbuildinfo",
    "compile": "tsc -p tsconfig.build.json",
    "postcompile": "tsc-alias -p tsconfig.build.json --outDir dist && tsc-esm-fix --tsconfig=tsconfig.build.json",
    "build": "bun run clean && bun run compile && bun run postcompile",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.0.1",
    "prettier": "^3.9.1",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsc-esm-fix": "^3.1.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
