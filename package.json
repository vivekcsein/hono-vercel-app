{
  "name": "hono-vercel-app",
  "description": "A hono web services/backend project starter to host on vercel",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist && rimraf .tsbuildinfo",
    "compile": "vite build",
    "build": "bun run clean && bun run compile",
    "start": "node dist/index.js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "hono": "^4.12.27",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "prettier": "^3.9.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "vite": "^8.1.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
