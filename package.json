{
	"name": "hono-vercel-app",
	"version": "0.0.0",
	"description": "A hono web services/backend project starter to host on vercel",
	"type": "module",
	"main": "index.ts",
	"private": true,
	"scripts": {
		"dev": "bun --watch src/app/server.ts",
		"clean": "rimraf node_modules bun.lock dist",
		"start": "bun index.ts",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"verify": "bun run typecheck && bun run check"
	},
	"dependencies": {
		"hono": "^4.12.27",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/bun": "^1.3.14",
		"@vercel/node": "^5.8.22",
		"rimraf": "^6.1.3"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	}
}
